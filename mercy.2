<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BLACK DASHBOARD - Gambar CS</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
        :root {
            --bg: #000000;
            --bg-sidebar: #080808;
            --bg-card: #0d0d0d;
            --bg-card-alt: #141414;
            --bg-input: #1a1a1a;
            --accent: #e63946;
            --accent-dark: #b52d38;
            --accent-glow: rgba(230, 57, 70, 0.2);
            --green: #2ecc71;
            --green-glow: rgba(46, 204, 113, 0.25);
            --yellow: #f0c040;
            --yellow-glow: rgba(240, 192, 64, 0.15);
            --blue: #3498db;
            --text: #e8e8ed;
            --text-sec: #8888a0;
            --text-muted: #4a4a5a;
            --border: #1a1a1a;
            --border-light: #252525;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Inter', sans-serif;
            background: #060606;
            color: var(--text);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: flex-start;
            padding: 20px 0;
        }

        /* ===== PHONE FRAME ===== */
        .phone {
            width: 420px;
            height: 860px;
            background: var(--bg);
            border-radius: 36px;
            border: 2px solid #1a1a1a;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            position: relative;
            box-shadow: 0 0 80px rgba(0,0,0,0.8), 0 0 0 1px rgba(255,255,255,0.02);
        }

        /* ===== STATUS BAR ===== */
        .status-bar {
            height: 44px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 24px;
            font-size: 12px;
            font-weight: 600;
            color: var(--text);
            flex-shrink: 0;
        }

        .status-bar-right { display: flex; gap: 6px; align-items: center; font-size: 11px; }
        .status-bar-right i { font-size: 12px; }

        /* ===== INNER LAYOUT: SIDEBAR + CONTENT ===== */
        .inner {
            flex: 1;
            display: flex;
            overflow: hidden;
        }

        /* ===== LEFT SIDEBAR ===== */
        .sidebar {
            width: 88px;
            background: var(--bg-sidebar);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            flex-shrink: 0;
        }

        .sidebar-label {
            font-size: 7px;
            font-weight: 800;
            color: var(--text-muted);
            letter-spacing: 2px;
            text-transform: uppercase;
            padding: 14px 10px 6px;
            text-align: center;
        }

        .sidebar-menu {
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 2px;
            padding: 4px 6px;
        }

        .sidebar-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 5px;
            padding: 10px 4px 8px;
            border-radius: 10px;
            cursor: pointer;
            transition: all 0.25s;
            text-decoration: none;
            position: relative;
        }

        .sidebar-item:hover {
            background: rgba(255,255,255,0.03);
        }

        .sidebar-item.active {
            background: var(--accent-glow);
        }

        .sidebar-item.active .sb-icon {
            color: var(--accent);
            filter: drop-shadow(0 0 6px rgba(230,57,70,0.4));
        }

        .sidebar-item.active .sb-label {
            color: var(--accent);
            font-weight: 700;
        }

        .sidebar-item.active::before {
            content: '';
            position: absolute;
            left: 0;
            top: 10px;
            bottom: 10px;
            width: 3px;
            border-radius: 0 3px 3px 0;
            background: var(--accent);
            box-shadow: 0 0 8px rgba(230,57,70,0.4);
        }

        .sb-icon {
            font-size: 18px;
            color: var(--text-muted);
            transition: all 0.25s;
        }

        .sb-label {
            font-size: 8.5px;
            font-weight: 500;
            color: var(--text-muted);
            text-align: center;
            line-height: 1.2;
            transition: all 0.25s;
        }

        /* Sidebar bottom section */
        .sidebar-bottom {
            padding: 6px;
            border-top: 1px solid var(--border);
        }

        .sidebar-bottom-label {
            font-size: 7px;
            font-weight: 800;
            color: var(--text-muted);
            letter-spacing: 2px;
            text-transform: uppercase;
            padding: 6px 4px 4px;
            text-align: center;
        }

        .sidebar-bottom-items {
            display: flex;
            flex-direction: column;
            gap: 2px;
        }

        .sb-admin-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 4px;
            padding: 8px 6px;
            border-radius: 8px;
            background: var(--yellow-glow);
            border: 1px solid rgba(240,192,64,0.15);
            cursor: pointer;
            transition: all 0.25s;
            margin-top: 2px;
        }

        .sb-admin-btn:hover {
            background: rgba(240,192,64,0.22);
        }

        .sb-admin-btn i {
            font-size: 11px;
            color: var(--yellow);
        }

        .sb-admin-btn span {
            font-size: 8px;
            font-weight: 800;
            color: var(--yellow);
            letter-spacing: 1px;
        }

        /* ===== RIGHT CONTENT ===== */
        .content-col {
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        /* ===== HEADER ===== */
        .header {
            padding: 12px 16px 10px;
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .header-left {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .user-avatar {
            width: 30px;
            height: 30px;
            border-radius: 8px;
            background: linear-gradient(135deg, var(--accent) 0%, #8b1a24 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 11px;
            font-weight: 800;
            color: #fff;
        }

        .user-info { display: flex; flex-direction: column; }

        .user-name {
            font-size: 12px;
            font-weight: 700;
            color: var(--text);
        }

        .user-meta {
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .user-role {
            font-size: 9px;
            color: var(--text-muted);
        }

        .online-badge {
            display: inline-flex;
            align-items: center;
            gap: 3px;
            font-size: 8px;
            font-weight: 600;
            color: var(--green);
            background: var(--green-glow);
            padding: 1px 6px;
            border-radius: 8px;
        }

        .online-dot {
            width: 4px; height: 4px;
            border-radius: 50%;
            background: var(--green);
            animation: pdot 2s infinite;
        }

        @keyframes pdot {
            0%,100% { opacity:1; box-shadow: 0 0 4px var(--green); }
            50% { opacity:0.3; box-shadow: none; }
        }

        .header-notif {
            width: 32px; height: 32px;
            border-radius: 8px;
            background: var(--bg-card);
            border: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--text-sec);
            font-size: 13px;
            cursor: pointer;
            position: relative;
            transition: all 0.2s;
        }

        .header-notif:hover { color: var(--text); border-color: var(--border-light); }

        .header-notif .notif-dot {
            position: absolute;
            top: 5px; right: 6px;
            width: 5px; height: 5px;
            border-radius: 50%;
            background: var(--accent);
        }

        /* ===== SCROLLABLE CONTENT ===== */
        .scroll-area {
            flex: 1;
            overflow-y: auto;
            padding: 0 14px 14px;
            scrollbar-width: none;
        }

        .scroll-area::-webkit-scrollbar { display: none; }

        /* ===== HERO ===== */
        .hero {
            background: linear-gradient(135deg, var(--accent) 0%, var(--accent-dark) 55%, #8b1a24 100%);
            border-radius: 14px;
            padding: 16px 16px 14px;
            margin-bottom: 12px;
            position: relative;
            overflow: hidden;
        }

        .hero::before {
            content: '';
            position: absolute;
            top: -40px; right: -15px;
            width: 100px; height: 100px;
            background: radial-gradient(circle, rgba(255,255,255,0.07) 0%, transparent 70%);
        }

        .hero-chip {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            background: rgba(0,0,0,0.3);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 14px;
            padding: 3px 9px;
            font-size: 8px;
            font-weight: 700;
            color: rgba(255,255,255,0.8);
            letter-spacing: 0.8px;
            text-transform: uppercase;
            margin-bottom: 8px;
        }

        .hero-chip i { font-size: 8px; }

        .hero-title {
            font-size: 16px;
            font-weight: 800;
            color: #fff;
            margin-bottom: 4px;
        }

        .hero-desc {
            font-size: 10px;
            color: rgba(255,255,255,0.6);
            line-height: 1.5;
        }

        /* ===== FILTER PILLS ===== */
        .filter-row {
            display: flex;
            gap: 5px;
            margin-bottom: 12px;
            overflow-x: auto;
            scrollbar-width: none;
        }

        .filter-row::-webkit-scrollbar { display: none; }

        .filter-pill {
            flex-shrink: 0;
            display: inline-flex;
            align-items: center;
            gap: 4px;
            padding: 6px 11px;
            border-radius: 18px;
            font-size: 10px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.25s;
            border: 1px solid var(--border);
            background: var(--bg-card);
            color: var(--text-sec);
        }

        .filter-pill:hover { border-color: var(--border-light); color: var(--text); }

        .filter-pill.active {
            background: var(--accent);
            color: #fff;
            border-color: var(--accent);
            box-shadow: 0 2px 10px var(--accent-glow);
        }

        .filter-pill i { font-size: 9px; }

        /* ===== SECTION HEAD ===== */
        .section-head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 10px;
        }

        .section-head-left {
            display: flex;
            align-items: center;
            gap: 7px;
        }

        .section-icon {
            width: 26px; height: 26px;
            border-radius: 7px;
            background: var(--accent-glow);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--accent);
            font-size: 11px;
        }

        .section-title {
            font-size: 12px;
            font-weight: 700;
        }

        .section-count {
            font-size: 9px;
            color: var(--text-muted);
        }

        .search-mini {
            position: relative;
        }

        .search-mini input {
            width: 110px;
            height: 28px;
            border-radius: 7px;
            border: 1px solid var(--border);
            background: var(--bg-input);
            color: var(--text);
            font-size: 10px;
            padding: 0 8px 0 26px;
            font-family: 'Inter', sans-serif;
            outline: none;
            transition: all 0.25s;
        }

        .search-mini input::placeholder { color: var(--text-muted); }

        .search-mini input:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 2px var(--accent-glow);
            width: 130px;
        }

        .search-mini i {
            position: absolute;
            left: 8px; top: 50%;
            transform: translateY(-50%);
            font-size: 9px;
            color: var(--text-muted);
        }

        /* ===== CARD GRID 2 KOLOM ===== */
        .card-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 8px;
        }

        .bank-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 10px;
            overflow: hidden;
            cursor: pointer;
            transition: all 0.3s;
        }

        .bank-card:hover {
            border-color: rgba(230,57,70,0.3);
            transform: translateY(-2px);
            box-shadow: 0 6px 18px rgba(0,0,0,0.5);
        }

        .bank-card:active { transform: scale(0.96); }

        .bank-card-img {
            width: 100%;
            height: 100px;
            object-fit: cover;
            display: block;
            background: var(--bg-card-alt);
        }

        .bank-card-body {
            padding: 7px 9px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .bank-card-name {
            font-size: 9.5px;
            font-weight: 700;
            color: var(--text);
        }

        .bank-card-badge {
            font-size: 7px;
            font-weight: 700;
            padding: 2px 5px;
            border-radius: 6px;
        }

        .badge-bank { background: rgba(52,152,219,0.12); color: #5dade2; }
        .badge-ewallet { background: rgba(46,204,113,0.12); color: #58d68d; }
        .badge-qris { background: rgba(243,156,18,0.12); color: #f5b041; }

        .no-results {
            display: none;
            text-align: center;
            padding: 24px 10px;
            color: var(--text-muted);
            font-size: 11px;
            grid-column: 1 / -1;
        }

        .no-results i { font-size: 24px; margin-bottom: 6px; display: block; opacity: 0.3; }
        .no-results.show { display: block; }

        /* ===== HOME INDICATOR ===== */
        .home-indicator {
            height: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .home-indicator-bar {
            width: 110px;
            height: 4px;
            border-radius: 2px;
            background: #2a2a2a;
        }

        /* ===== BOTTOM SHEET MODAL ===== */
        .modal-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.8);
            backdrop-filter: blur(8px);
            z-index: 300;
            display: none;
            align-items: flex-end;
            justify-content: center;
        }

        .modal-overlay.show { display: flex; }

        .modal-sheet {
            width: 420px;
            max-width: 100vw;
            background: #111;
            border-radius: 20px 20px 0 0;
            overflow: hidden;
            animation: slideUp 0.35s cubic-bezier(0.16,1,0.3,1);
        }

        @keyframes slideUp {
            from { transform: translateY(100%); }
            to { transform: translateY(0); }
        }

        .modal-handle {
            width: 36px; height: 4px;
            border-radius: 2px;
            background: #333;
            margin: 10px auto 0;
        }

        .modal-sheet-img {
            width: 100%;
            height: 200px;
            object-fit: cover;
            display: block;
            margin-top: 12px;
        }

        .modal-sheet-body {
            padding: 16px 20px 30px;
        }

        .modal-sheet-title {
            font-size: 16px;
            font-weight: 800;
            margin-bottom: 6px;
        }

        .modal-sheet-desc {
            font-size: 12px;
            color: var(--text-sec);
            line-height: 1.6;
            margin-bottom: 18px;
        }

        .modal-sheet-close {
            width: 100%;
            padding: 12px;
            border-radius: 12px;
            border: none;
            background: var(--accent);
            color: #fff;
            font-size: 13px;
            font-weight: 700;
            font-family: 'Inter', sans-serif;
            cursor: pointer;
            transition: background 0.2s;
        }

        .modal-sheet-close:hover { background: var(--accent-dark); }

        /* ===== TOAST ===== */
        .toast-wrap {
            position: fixed;
            top: 50px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 400;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 6px;
            pointer-events: none;
        }

        .toast {
            background: #1a1a1a;
            border: 1px solid var(--border-light);
            border-radius: 10px;
            padding: 8px 16px;
            font-size: 11px;
            font-weight: 600;
            color: var(--text);
            box-shadow: 0 8px 30px rgba(0,0,0,0.6);
            display: flex;
            align-items: center;
            gap: 7px;
            animation: tIn 0.3s ease, tOut 0.3s ease 2s forwards;
            pointer-events: auto;
        }

        .toast i { color: var(--accent); font-size: 12px; }

        @keyframes tIn { from { opacity:0; transform:translateY(-12px); } to { opacity:1; transform:translateY(0); } }
        @keyframes tOut { from { opacity:1; transform:translateY(0); } to { opacity:0; transform:translateY(-12px); } }

        /* ===== RESPONSIVE ===== */
        @media (max-width: 440px) {
            body { padding: 0; }
            .phone { width: 100%; height: 100vh; border-radius: 0; border: none; }
            .modal-sheet { width: 100%; }
        }
    </style>
</head>
<body>

    <div class="phone">

        <!-- STATUS BAR -->
        <div class="status-bar">
            <div id="liveTime">00:00</div>
            <div class="status-bar-right">
                <i class="fas fa-signal"></i>
                <i class="fas fa-wifi"></i>
                <i class="fas fa-battery-full"></i>
            </div>
        </div>

        <!-- INNER: SIDEBAR + CONTENT -->
        <div class="inner">

            <!-- LEFT SIDEBAR -->
            <nav class="sidebar">
                <div class="sidebar-label">Main Menu</div>
                <div class="sidebar-menu">
                    <div class="sidebar-item" data-page="beranda">
                        <i class="fas fa-house sb-icon"></i>
                        <span class="sb-label">Beranda</span>
                    </div>
                    <div class="sidebar-item" data-page="shortcut">
                        <i class="fas fa-link sb-icon"></i>
                        <span class="sb-label">Shortcut Cs</span>
                    </div>
                    <div class="sidebar-item" data-page="jadwal">
                        <i class="fas fa-calendar-days sb-icon"></i>
                        <span class="sb-label">Jadwal<br>Pasaran</span>
                    </div>
                    <div class="sidebar-item" data-page="prediksi">
                        <i class="fas fa-chart-line sb-icon"></i>
                        <span class="sb-label">Prediksi<br>Togel</span>
                    </div>
                    <div class="sidebar-item active" data-page="gambar">
                        <i class="fas fa-camera sb-icon"></i>
                        <span class="sb-label">Gambar<br>CS</span>
                    </div>
                </div>
                <div class="sidebar-bottom">
                    <div class="sidebar-bottom-label">Lainnya</div>
                    <div class="sidebar-bottom-items">
                        <div class="sidebar-item" data-page="settings" style="padding:8px 4px 6px;">
                            <i class="fas fa-gear sb-icon"></i>
                            <span class="sb-label">Settings</span>
                        </div>
                        <div class="sb-admin-btn" id="adminBtn">
                            <i class="fas fa-user-shield"></i>
                            <span>ADMIN</span>
                        </div>
                    </div>
                </div>
            </nav>

            <!-- RIGHT CONTENT COLUMN -->
            <div class="content-col">

                <!-- HEADER -->
                <div class="header">
                    <div class="header-left">
                        <div class="user-avatar">EH</div>
                        <div class="user-info">
                            <span class="user-name">eriharianto</span>
                            <div class="user-meta">
                                <span class="user-role">Administrator</span>
                                <span class="online-badge"><span class="online-dot"></span> Online</span>
                            </div>
                        </div>
                    </div>
                    <div class="header-notif" id="notifBtn">
                        <i class="fas fa-bell"></i>
                        <span class="notif-dot"></span>
                    </div>
                </div>

                <!-- SCROLL AREA -->
                <div class="scroll-area">

                    <!-- HERO -->
                    <div class="hero">
                        <div class="hero-chip"><i class="fas fa-image"></i> KOLEKSI GAMBAR</div>
                        <div class="hero-title">Gambar CS Livechat</div>
                        <div class="hero-desc">Kumpulan gambar profil bank & e-wallet untuk verifikasi transaksi livechat.</div>
                    </div>

                    <!-- FILTER PILLS -->
                    <div class="filter-row" id="filterRow">
                        <div class="filter-pill" data-filter="all"><i class="fas fa-layer-group"></i> Semua</div>
                        <div class="filter-pill" data-filter="rrn"><i class="fas fa-qrcode"></i> RRN QRIS</div>
                        <div class="filter-pill active" data-filter="bank"><i class="fas fa-building-columns"></i> Bank</div>
                        <div class="filter-pill" data-filter="ewallet"><i class="fas fa-wallet"></i> E-Wallet</div>
                        <div class="filter-pill" data-filter="qris"><i class="fas fa-receipt"></i> Bukti QRIS</div>
                    </div>

                    <!-- SECTION HEAD -->
                    <div class="section-head">
                        <div class="section-head-left">
                            <div class="section-icon"><i class="fas fa-building-columns"></i></div>
                            <div>
                                <div class="section-title">Profile Bank & E-Wallet</div>
                                <div class="section-count" id="itemCount">5 item</div>
                            </div>
                        </div>
                        <div class="search-mini">
                            <i class="fas fa-magnifying-glass"></i>
                            <input type="text" id="searchInput" placeholder="Cari...">
                        </div>
                    </div>

                    <!-- CARD GRID -->
                    <div class="card-grid" id="cardGrid"></div>

                </div>

                <!-- HOME INDICATOR -->
                <div class="home-indicator">
                    <div class="home-indicator-bar"></div>
                </div>

            </div>
        </div>

    </div>

    <!-- BOTTOM SHEET MODAL -->
    <div class="modal-overlay" id="modalOverlay">
        <div class="modal-sheet">
            <div class="modal-handle"></div>
            <img class="modal-sheet-img" id="modalImg" src="" alt="Preview">
            <div class="modal-sheet-body">
                <h3 class="modal-sheet-title" id="modalTitle"></h3>
                <p class="modal-sheet-desc" id="modalDesc"></p>
                <button class="modal-sheet-close" id="modalCloseBtn">Tutup</button>
            </div>
        </div>
    </div>

    <!-- TOAST -->
    <div class="toast-wrap" id="toastWrap"></div>

    <script>
        // ===== DATA =====
        const bankData = [
            { id:1, name:'BANK BCA', type:'bank', badge:'BANK', img:'https://picsum.photos/seed/sbca01/400/280.jpg', desc:'Gambar profil resmi Bank BCA untuk verifikasi deposit via transfer BCA.' },
            { id:2, name:'BANK BRI', type:'bank', badge:'BANK', img:'https://picsum.photos/seed/sbri02/400/280.jpg', desc:'Gambar profil Bank BRI untuk keperluan livechat dan konfirmasi pembayaran.' },
            { id:3, name:'BANK BNI', type:'bank', badge:'BANK', img:'https://picsum.photos/seed/sbni03/400/280.jpg', desc:'Profil Bank BNI untuk verifikasi deposit bank BNI oleh tim CS.' },
            { id:4, name:'BANK MANDIRI', type:'bank', badge:'BANK', img:'https://picsum.photos/seed/smdr04/400/280.jpg', desc:'Profil Bank Mandiri untuk konfirmasi transaksi di livechat.' },
            { id:5, name:'BANK CIMB', type:'bank', badge:'BANK', img:'https://picsum.photos/seed/scmb05/400/280.jpg', desc:'Gambar profil Bank CIMB Niaga untuk proses verifikasi CS.' },
            { id:6, name:'DANA', type:'ewallet', badge:'E-WALLET', img:'https://picsum.photos/seed/sdan06/400/280.jpg', desc:'Gambar profil DANA untuk verifikasi top-up dan pembayaran e-wallet.' },
            { id:7, name:'OVO', type:'ewallet', badge:'E-WALLET', img:'https://picsum.photos/seed/sovo07/400/280.jpg', desc:'Profil OVO untuk verifikasi transaksi via OVO di livechat.' },
            { id:8, name:'GO PAY', type:'ewallet', badge:'E-WALLET', img:'https://picsum.photos/seed/sgpy08/400/280.jpg', desc:'Profil GoPay untuk konfirmasi pembayaran e-wallet.' },
            { id:9, name:'SHOPEE PAY', type:'ewallet', badge:'E-WALLET', img:'https://picsum.photos/seed/sspy09/400/280.jpg', desc:'Profil ShopeePay untuk verifikasi deposit via ShopeePay.' },
            { id:10, name:'BUKTI RRN QRIS', type:'qris', badge:'QRIS', img:'https://picsum.photos/seed/sqr10/400/280.jpg', desc:'Contoh bukti RRN QRIS untuk verifikasi deposit otomatis.' }
        ];

        const cardGrid = document.getElementById('cardGrid');
        const itemCount = document.getElementById('itemCount');
        const searchInput = document.getElementById('searchInput');
        const toastWrap = document.getElementById('toastWrap');

        // ===== RENDER =====
        function badgeClass(b) {
            return b === 'BANK' ? 'badge-bank' : b === 'E-WALLET' ? 'badge-ewallet' : 'badge-qris';
        }

        function renderGrid(data) {
            cardGrid.innerHTML = '';
            if (!data.length) {
                cardGrid.innerHTML = '<div class="no-results show"><i class="fas fa-face-meh"></i>Tidak ditemukan</div>';
                itemCount.textContent = '0 item';
                return;
            }
            itemCount.textContent = data.length + ' item';
            data.forEach(item => {
                const el = document.createElement('div');
                el.className = 'bank-card';
                el.innerHTML = `
                    <img class="bank-card-img" src="${item.img}" alt="${item.name}" loading="lazy">
                    <div class="bank-card-body">
                        <span class="bank-card-name">${item.name}</span>
                        <span class="bank-card-badge ${badgeClass(item.badge)}">${item.badge}</span>
                    </div>`;
                el.addEventListener('click', () => openModal(item));
                cardGrid.appendChild(el);
            });
        }

        // Awal: tampilkan bank saja
        renderGrid(bankData.filter(i => i.type === 'bank'));

        // ===== FILTER =====
        let currentFilter = 'bank';
        document.getElementById('filterRow').addEventListener('click', e => {
            const pill = e.target.closest('.filter-pill');
            if (!pill) return;
            document.querySelectorAll('.filter-pill').forEach(p => p.classList.remove('active'));
            pill.classList.add('active');
            currentFilter = pill.dataset.filter;
            applyFilters();
            toast(pill.textContent.trim());
        });

        searchInput.addEventListener('input', applyFilters);

        function applyFilters() {
            const q = searchInput.value.toLowerCase().trim();
            let d = bankData;
            if (currentFilter !== 'all') d = d.filter(i => i.type === currentFilter);
            if (q) d = d.filter(i => i.name.toLowerCase().includes(q));
            renderGrid(d);
        }

        // ===== SIDEBAR NAV =====
        document.querySelectorAll('.sidebar-item').forEach(item => {
            item.addEventListener('click', () => {
                document.querySelectorAll('.sidebar-item').forEach(s => s.classList.remove('active'));
                item.classList.add('active');
                const page = item.dataset.page;

                if (page === 'gambar') {
                    currentFilter = 'bank';
                    document.querySelectorAll('.filter-pill').forEach(p => p.classList.remove('active'));
                    document.querySelector('[data-filter="bank"]').classList.add('active');
                    searchInput.value = '';
                    applyFilters();
                }

                toast(item.querySelector('.sb-label').textContent.replace(/\n/g, ' '));
            });
        });

        // ===== ADMIN BTN =====
        document.getElementById('adminBtn').addEventListener('click', () => toast('Panel Admin'));
        document.getElementById('notifBtn').addEventListener('click', () => toast('Tidak ada notifikasi baru'));

        // ===== MODAL =====
        const modalOverlay = document.getElementById('modalOverlay');

        function openModal(item) {
            document.getElementById('modalImg').src = item.img;
            document.getElementById('modalTitle').textContent = item.name;
            document.getElementById('modalDesc').textContent = item.desc;
            modalOverlay.classList.add('show');
        }

        function closeModal() { modalOverlay.classList.remove('show'); }

        document.getElementById('modalCloseBtn').addEventListener('click', closeModal);
        modalOverlay.addEventListener('click', e => { if (e.target === modalOverlay) closeModal(); });
        document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

        // ===== TOAST =====
        function toast(msg) {
            const t = document.createElement('div');
            t.className = 'toast';
            t.innerHTML = `<i class="fas fa-circle-info"></i> ${msg}`;
            toastWrap.appendChild(t);
            setTimeout(() => { if (t.parentNode) t.remove(); }, 2400);
        }

        // ===== CLOCK =====
        function tick() {
            const n = new Date();
            document.getElementById('liveTime').textContent =
                String(n.getHours()).padStart(2,'0') + ':' + String(n.getMinutes()).padStart(2,'0');
        }
        tick();
        setInterval(tick, 10000);
    </script>

</body>
</html>
