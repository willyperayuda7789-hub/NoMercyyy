<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Event Linetogel // FUTURE NEXUS</title>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;700;900&family=Share+Tech+Mono&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        :root {
            --bg: #020408;
            --bg-panel: rgba(4, 20, 40, 0.85);
            --card: rgba(6, 28, 52, 0.7);
            --card-hover: rgba(10, 40, 70, 0.8);
            --border: rgba(0, 255, 200, 0.12);
            --border-strong: rgba(0, 255, 200, 0.3);
            --accent: #00ffc8;
            --accent-alt: #00b4d8;
            --accent-dim: rgba(0, 255, 200, 0.08);
            --accent-glow: rgba(0, 255, 200, 0.35);
            --neon-pink: #ff2d7b;
            --neon-blue: #00aaff;
            --fg: #d0f0ea;
            --fg-bright: #f0fffc;
            --fg-muted: #4a8a80;
            --success: #00ff88;
            --danger: #ff3355;
            --warning: #ffaa00;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Share Tech Mono', monospace;
            background: var(--bg);
            color: var(--fg);
            min-height: 100vh;
            overflow-x: hidden;
            position: relative;
        }

        /* ===== SCANLINES OVERLAY ===== */
        body::after {
            content: '';
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100%;
            background: repeating-linear-gradient(
                0deg,
                transparent,
                transparent 2px,
                rgba(0, 255, 200, 0.015) 2px,
                rgba(0, 255, 200, 0.015) 4px
            );
            pointer-events: none;
            z-index: 9998;
        }

        /* ===== CYBER GRID ===== */
        .cyber-grid {
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100%;
            background:
                linear-gradient(rgba(0,255,200,0.03) 1px, transparent 1px),
                linear-gradient(90deg, rgba(0,255,200,0.03) 1px, transparent 1px);
            background-size: 80px 80px;
            z-index: 0;
            pointer-events: none;
            animation: gridScroll 20s linear infinite;
        }

        @keyframes gridScroll {
            0% { transform: perspective(500px) rotateX(0deg) translateY(0); }
            100% { transform: perspective(500px) rotateX(0deg) translateY(80px); }
        }

        /* ===== NEON ORBS ===== */
        .neon-orb {
            position: fixed;
            border-radius: 50%;
            filter: blur(100px);
            pointer-events: none;
            z-index: 0;
        }

        .neon-orb.o1 {
            width: 600px; height: 600px;
            background: radial-gradient(circle, rgba(0,255,200,0.12), transparent 70%);
            top: -200px; right: -150px;
            animation: orbDrift 15s ease-in-out infinite;
        }

        .neon-orb.o2 {
            width: 500px; height: 500px;
            background: radial-gradient(circle, rgba(0,170,255,0.08), transparent 70%);
            bottom: -150px; left: -200px;
            animation: orbDrift 18s ease-in-out infinite reverse;
        }

        .neon-orb.o3 {
            width: 300px; height: 300px;
            background: radial-gradient(circle, rgba(255,45,123,0.06), transparent 70%);
            top: 40%; left: 30%;
            animation: orbDrift 12s ease-in-out infinite 3s;
        }

        @keyframes orbDrift {
            0%, 100% { transform: translate(0, 0); }
            25% { transform: translate(40px, -30px); }
            50% { transform: translate(-20px, 50px); }
            75% { transform: translate(30px, 20px); }
        }

        /* ===== DATA RAIN (Canvas) ===== */
        #dataRain {
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100%;
            z-index: 0;
            pointer-events: none;
            opacity: 0.4;
        }

        /* ===== HUD CORNERS ===== */
        .hud-corner {
            position: fixed;
            width: 80px; height: 80px;
            z-index: 5;
            pointer-events: none;
        }
        .hud-corner.tl { top: 12px; left: 12px; border-top: 2px solid var(--border-strong); border-left: 2px solid var(--border-strong); }
        .hud-corner.tr { top: 12px; right: 12px; border-top: 2px solid var(--border-strong); border-right: 2px solid var(--border-strong); }
        .hud-corner.bl { bottom: 12px; left: 12px; border-bottom: 2px solid var(--border-strong); border-left: 2px solid var(--border-strong); }
        .hud-corner.br { bottom: 12px; right: 12px; border-bottom: 2px solid var(--border-strong); border-right: 2px solid var(--border-strong); }

        /* ===== HEADER ===== */
        header {
            position: relative;
            z-index: 10;
            padding: 0;
            border-bottom: 1px solid var(--border);
            background: var(--bg-panel);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
        }

        .header-line {
            height: 2px;
            background: linear-gradient(90deg, transparent, var(--accent), var(--neon-blue), var(--accent), transparent);
            animation: linePulse 3s ease-in-out infinite;
        }

        @keyframes linePulse {
            0%, 100% { opacity: 0.6; }
            50% { opacity: 1; }
        }

        .header-inner {
            max-width: 1400px;
            margin: 0 auto;
            padding: 16px 24px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 12px;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 14px;
        }

        .logo-hex {
            width: 50px; height: 50px;
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .logo-hex svg {
            position: absolute;
            width: 50px; height: 50px;
            filter: drop-shadow(0 0 8px var(--accent-glow));
            animation: hexRotate 20s linear infinite;
        }

        @keyframes hexRotate {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }

        .logo-hex span {
            font-family: 'Orbitron', sans-serif;
            font-size: 14px;
            font-weight: 900;
            color: var(--accent);
            z-index: 1;
            text-shadow: 0 0 10px var(--accent-glow);
        }

        .logo-text-wrap {}

        .logo-text {
            font-family: 'Orbitron', sans-serif;
            font-weight: 900;
            font-size: 20px;
            letter-spacing: 4px;
            color: var(--fg-bright);
            text-shadow: 0 0 20px rgba(0,255,200,0.3);
        }

        .logo-sub {
            font-size: 10px;
            color: var(--fg-muted);
            letter-spacing: 5px;
            text-transform: uppercase;
            margin-top: 2px;
        }

        .logo-sub::before {
            content: '// ';
            color: var(--accent);
        }

        .header-right {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .sys-clock {
            font-family: 'Orbitron', sans-serif;
            font-size: 13px;
            color: var(--accent);
            letter-spacing: 2px;
            text-shadow: 0 0 8px var(--accent-glow);
        }

        .hud-stat {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 6px 14px;
            border: 1px solid var(--border);
            background: var(--accent-dim);
            font-size: 11px;
            color: var(--fg-muted);
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        .hud-stat .val {
            font-family: 'Orbitron', sans-serif;
            font-weight: 700;
            font-size: 14px;
            color: var(--accent);
            text-shadow: 0 0 6px var(--accent-glow);
        }

        .status-dot {
            width: 7px; height: 7px;
            border-radius: 50%;
            background: var(--success);
            box-shadow: 0 0 6px var(--success), 0 0 12px var(--success);
            animation: dotPulse 2s ease-in-out infinite;
        }

        @keyframes dotPulse {
            0%, 100% { opacity: 1; transform: scale(1); }
            50% { opacity: 0.4; transform: scale(0.7); }
        }

        /* ===== HERO ===== */
        .hero {
            position: relative;
            z-index: 10;
            padding: 56px 24px 36px;
            text-align: center;
        }

        .hero-tag {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            padding: 6px 20px;
            border: 1px solid var(--border-strong);
            background: var(--accent-dim);
            font-size: 10px;
            font-weight: 700;
            color: var(--accent);
            text-transform: uppercase;
            letter-spacing: 4px;
            margin-bottom: 28px;
            animation: fadeInDown 0.7s ease;
        }

        .hero-tag .dot-blink {
            width: 6px; height: 6px;
            background: var(--accent);
            animation: dotPulse 1.5s ease-in-out infinite;
        }

        .hero h1 {
            font-family: 'Orbitron', sans-serif;
            font-size: clamp(28px, 6vw, 60px);
            font-weight: 900;
            line-height: 1.1;
            margin-bottom: 8px;
            animation: glitchIn 1s ease 0.2s both;
            position: relative;
        }

        .hero h1 .glitch {
            position: relative;
            display: inline-block;
            color: var(--fg-bright);
            text-shadow: 0 0 30px rgba(0,255,200,0.4);
        }

        .hero h1 .glitch::before,
        .hero h1 .glitch::after {
            content: attr(data-text);
            position: absolute;
            top: 0; left: 0;
            width: 100%; height: 100%;
        }

        .hero h1 .glitch::before {
            color: var(--neon-pink);
            animation: glitch1 4s infinite linear;
            clip-path: inset(0 0 60% 0);
        }

        .hero h1 .glitch::after {
            color: var(--neon-blue);
            animation: glitch2 4s infinite linear;
            clip-path: inset(40% 0 0 0);
        }

        @keyframes glitch1 {
            0%, 92%, 100% { transform: translate(0); }
            93% { transform: translate(-4px, 1px); }
            95% { transform: translate(3px, -1px); }
            97% { transform: translate(-2px, 2px); }
        }

        @keyframes glitch2 {
            0%, 90%, 100% { transform: translate(0); }
            91% { transform: translate(3px, -2px); }
            94% { transform: translate(-3px, 1px); }
            96% { transform: translate(2px, -1px); }
        }

        .hero-sub {
            font-size: 14px;
            color: var(--fg-muted);
            max-width: 520px;
            margin: 16px auto 0;
            line-height: 1.8;
            letter-spacing: 0.5px;
            animation: fadeInUp 0.8s ease 0.4s both;
        }

        .hero-sub .cmd {
            color: var(--accent);
            text-shadow: 0 0 4px var(--accent-glow);
        }

        @keyframes glitchIn {
            0% { opacity: 0; transform: translateY(10px) skewX(-2deg); filter: blur(4px); }
            50% { filter: blur(0); transform: translateY(-2px) skewX(1deg); }
            100% { opacity: 1; transform: translateY(0) skewX(0); }
        }

        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(16px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @keyframes fadeInDown {
            from { opacity: 0; transform: translateY(-10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* ===== TOOLBAR ===== */
        .toolbar {
            position: relative;
            z-index: 10;
            max-width: 1400px;
            margin: 0 auto 28px;
            padding: 0 24px;
            display: flex;
            align-items: center;
            gap: 12px;
            flex-wrap: wrap;
            animation: fadeInUp 0.8s ease 0.5s both;
        }

        .search-wrap {
            flex: 1;
            min-width: 220px;
            position: relative;
        }

        .search-wrap .prefix {
            position: absolute;
            left: 14px; top: 50%;
            transform: translateY(-50%);
            color: var(--fg-muted);
            font-size: 12px;
            pointer-events: none;
        }

        .search-wrap input {
            width: 100%;
            padding: 12px 14px 12px 58px;
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: 4px;
            color: var(--fg);
            font-family: 'Share Tech Mono', monospace;
            font-size: 13px;
            outline: none;
            transition: all 0.3s;
            letter-spacing: 0.5px;
        }

        .search-wrap input::placeholder { color: var(--fg-muted); }

        .search-wrap input:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px var(--accent-dim), 0 0 20px rgba(0,255,200,0.08);
        }

        .cyber-btn {
            padding: 11px 18px;
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: 4px;
            color: var(--fg-muted);
            font-family: 'Share Tech Mono', monospace;
            font-size: 12px;
            letter-spacing: 1px;
            text-transform: uppercase;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all 0.25s;
            position: relative;
            overflow: hidden;
        }

        .cyber-btn::after {
            content: '';
            position: absolute;
            top: 0; left: -100%;
            width: 100%; height: 100%;
            background: linear-gradient(90deg, transparent, rgba(0,255,200,0.06), transparent);
            transition: left 0.5s;
        }

        .cyber-btn:hover::after { left: 100%; }

        .cyber-btn:hover {
            border-color: var(--accent);
            color: var(--accent);
            box-shadow: 0 0 15px rgba(0,255,200,0.1);
        }

        .cyber-btn.active {
            border-color: var(--accent);
            color: var(--accent);
            background: var(--accent-dim);
        }

        .cyber-btn.primary {
            background: linear-gradient(135deg, rgba(0,255,200,0.15), rgba(0,170,255,0.1));
            border-color: var(--border-strong);
            color: var(--accent);
            box-shadow: 0 0 20px rgba(0,255,200,0.1);
        }

        .cyber-btn.primary:hover {
            box-shadow: 0 0 30px rgba(0,255,200,0.2), inset 0 0 20px rgba(0,255,200,0.05);
            transform: translateY(-1px);
        }

        .cyber-btn.primary.spinning i { animation: spin 0.7s linear infinite; }

        @keyframes spin { to { transform: rotate(360deg); } }

        .view-group {
            display: flex;
            border: 1px solid var(--border);
            border-radius: 4px;
            overflow: hidden;
        }

        .view-group button {
            padding: 11px 14px;
            background: var(--card);
            border: none;
            color: var(--fg-muted);
            cursor: pointer;
            font-size: 13px;
            transition: all 0.2s;
            font-family: 'Share Tech Mono', monospace;
        }

        .view-group button + button { border-left: 1px solid var(--border); }

        .view-group button.active {
            background: var(--accent-dim);
            color: var(--accent);
        }

        .view-group button:hover:not(.active) { color: var(--fg); }

        /* ===== MAIN ===== */
        main {
            position: relative;
            z-index: 10;
            max-width: 1400px;
            margin: 0 auto;
            padding: 0 24px 80px;
        }

        /* ===== LOADING ===== */
        .loading-box {
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 100px 20px;
            gap: 28px;
        }

        .hex-loader {
            width: 60px; height: 60px;
            position: relative;
        }

        .hex-loader svg {
            width: 100%; height: 100%;
            animation: hexRotate 2s linear infinite;
            filter: drop-shadow(0 0 10px var(--accent-glow));
        }

        .loading-label {
            font-size: 12px;
            color: var(--fg-muted);
            letter-spacing: 3px;
            text-transform: uppercase;
        }

        .loading-bar {
            width: 200px;
            height: 2px;
            background: var(--border);
            border-radius: 1px;
            overflow: hidden;
        }

        .loading-bar-inner {
            height: 100%;
            background: var(--accent);
            border-radius: 1px;
            box-shadow: 0 0 10px var(--accent-glow);
            animation: loadBar 1.5s ease-in-out infinite;
        }

        @keyframes loadBar {
            0% { width: 0; margin-left: 0; }
            50% { width: 60%; margin-left: 20%; }
            100% { width: 0; margin-left: 100%; }
        }

        /* ===== ERROR ===== */
        .error-box {
            text-align: center;
            padding: 80px 20px;
        }

        .error-box .err-icon {
            font-size: 48px;
            color: var(--danger);
            margin-bottom: 20px;
            text-shadow: 0 0 20px rgba(255,51,85,0.4);
        }

        .error-box h3 {
            font-family: 'Orbitron', sans-serif;
            font-size: 18px;
            color: var(--fg-bright);
            margin-bottom: 12px;
            letter-spacing: 3px;
        }

        .error-box p {
            color: var(--fg-muted);
            font-size: 13px;
            margin-bottom: 24px;
            max-width: 420px;
            margin-left: auto;
            margin-right: auto;
            line-height: 1.8;
        }

        .error-box .err-code {
            font-size: 11px;
            color: var(--danger);
            letter-spacing: 2px;
            margin-bottom: 20px;
            opacity: 0.7;
        }

        /* ===== TABLE ===== */
        .panel {
            background: var(--bg-panel);
            border: 1px solid var(--border);
            border-radius: 4px;
            overflow: hidden;
            box-shadow: 0 0 40px rgba(0,255,200,0.03), 0 8px 32px rgba(0,0,0,0.4);
            position: relative;
            animation: panelIn 0.6s ease;
        }

        .panel::before {
            content: '';
            position: absolute;
            top: 0; left: 0;
            width: 100%; height: 1px;
            background: linear-gradient(90deg, transparent, var(--accent), transparent);
        }

        @keyframes panelIn {
            from { opacity: 0; transform: translateY(12px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .panel-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px 20px;
            border-bottom: 1px solid var(--border);
            background: rgba(0,255,200,0.02);
            font-size: 11px;
            color: var(--fg-muted);
            letter-spacing: 2px;
            text-transform: uppercase;
            flex-wrap: wrap;
            gap: 8px;
        }

        .panel-header .cnt {
            color: var(--accent);
            font-family: 'Orbitron', sans-serif;
            font-weight: 700;
            font-size: 13px;
            text-shadow: 0 0 6px var(--accent-glow);
        }

        .table-scroll {
            overflow-x: auto;
            scrollbar-width: thin;
            scrollbar-color: var(--border) transparent;
        }

        .table-scroll::-webkit-scrollbar { height: 5px; }
        .table-scroll::-webkit-scrollbar-track { background: transparent; }
        .table-scroll::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }

        .dtable {
            width: 100%;
            border-collapse: collapse;
            min-width: 700px;
        }

        .dtable thead {
            background: rgba(0,255,200,0.04);
            border-bottom: 1px solid var(--border-strong);
            position: sticky;
            top: 0;
            z-index: 2;
        }

        .dtable th {
            padding: 14px 18px;
            text-align: left;
            font-size: 10px;
            font-weight: 700;
            color: var(--accent);
            text-transform: uppercase;
            letter-spacing: 2.5px;
            white-space: nowrap;
            user-select: none;
            cursor: pointer;
            transition: all 0.2s;
            position: relative;
        }

        .dtable th:hover { color: var(--fg-bright); text-shadow: 0 0 8px var(--accent-glow); }

        .dtable th .srt {
            margin-left: 5px;
            font-size: 9px;
            opacity: 0.3;
            transition: opacity 0.2s;
        }

        .dtable th.sorted .srt { opacity: 1; color: var(--accent); }

        .dtable td {
            padding: 13px 18px;
            font-size: 13px;
            color: var(--fg);
            border-bottom: 1px solid rgba(0,255,200,0.04);
            vertical-align: top;
            line-height: 1.6;
            letter-spacing: 0.3px;
        }

        .dtable tbody tr {
            transition: all 0.2s;
            position: relative;
        }

        .dtable tbody tr::before {
            content: '';
            position: absolute;
            left: 0; top: 0;
            width: 2px; height: 100%;
            background: transparent;
            transition: background 0.2s;
        }

        .dtable tbody tr:hover {
            background: rgba(0,255,200,0.03);
        }

        .dtable tbody tr:hover::before {
            background: var(--accent);
            box-shadow: 0 0 8px var(--accent-glow);
        }

        .dtable tbody tr:last-child td { border-bottom: none; }

        .row-idx {
            font-family: 'Orbitron', sans-serif;
            font-size: 11px;
            color: var(--fg-muted);
            font-weight: 500;
            opacity: 0.6;
        }

        /* ===== CARD VIEW ===== */
        .card-grid {
            display: none;
            grid-template-columns: 1fr;
            gap: 14px;
        }

        .ev-card {
            background: var(--bg-panel);
            border: 1px solid var(--border);
            border-radius: 4px;
            padding: 18px;
            transition: all 0.3s;
            animation: cardSlide 0.5s ease both;
            position: relative;
            overflow: hidden;
        }

        .ev-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0;
            width: 3px; height: 100%;
            background: var(--accent);
            opacity: 0;
            transition: opacity 0.3s;
            box-shadow: 0 0 10px var(--accent-glow);
        }

        .ev-card:hover {
            border-color: var(--border-strong);
            box-shadow: 0 0 25px rgba(0,255,200,0.06);
        }

        .ev-card:hover::before { opacity: 1; }

        @keyframes cardSlide {
            from { opacity: 0; transform: translateX(-12px); }
            to { opacity: 1; transform: translateX(0); }
        }

        .ev-card .c-row {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            padding: 9px 0;
            border-bottom: 1px solid rgba(0,255,200,0.04);
            gap: 12px;
        }

        .ev-card .c-row:last-child { border-bottom: none; }

        .ev-card .c-label {
            font-size: 10px;
            font-weight: 700;
            color: var(--accent);
            text-transform: uppercase;
            letter-spacing: 2px;
            white-space: nowrap;
            min-width: 110px;
        }

        .ev-card .c-val {
            font-size: 13px;
            color: var(--fg);
            text-align: right;
            word-break: break-word;
            line-height: 1.5;
        }

        /* ===== BADGES ===== */
        .tag {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 3px 12px;
            border-radius: 2px;
            font-size: 10px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            white-space: nowrap;
            font-family: 'Share Tech Mono', monospace;
        }

        .tag-aktif {
            background: rgba(0,255,136,0.1);
            color: var(--success);
            border: 1px solid rgba(0,255,136,0.25);
            text-shadow: 0 0 6px rgba(0,255,136,0.3);
        }

        .tag-aktif::before {
            content: '';
            width: 5px; height: 5px;
            background: var(--success);
            border-radius: 50%;
            box-shadow: 0 0 4px var(--success);
            animation: dotPulse 1.5s ease-in-out infinite;
        }

        .tag-off {
            background: rgba(255,51,85,0.08);
            color: var(--danger);
            border: 1px solid rgba(255,51,85,0.2);
        }

        .tag-wait {
            background: rgba(0,170,255,0.08);
            color: var(--neon-blue);
            border: 1px solid rgba(0,170,255,0.2);
        }

        .tag-warn {
            background: rgba(255,170,0,0.08);
            color: var(--warning);
            border: 1px solid rgba(255,170,0,0.2);
        }

        .tag-neutral {
            background: rgba(74,138,128,0.08);
            color: var(--fg-muted);
            border: 1px solid rgba(74,138,128,0.2);
        }

        /* ===== NO RESULTS ===== */
        .no-data {
            text-align: center;
            padding: 60px 20px;
            color: var(--fg-muted);
        }

        .no-data i {
            font-size: 36px;
            margin-bottom: 16px;
            opacity: 0.3;
        }

        .no-data p { font-size: 13px; letter-spacing: 1px; }

        /* ===== TOAST ===== */
        .toast-stack {
            position: fixed;
            top: 20px; right: 20px;
            z-index: 9999;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .toast-msg {
            padding: 12px 18px;
            background: var(--bg-panel);
            border: 1px solid var(--border);
            border-radius: 4px;
            color: var(--fg);
            font-family: 'Share Tech Mono', monospace;
            font-size: 12px;
            display: flex;
            align-items: center;
            gap: 10px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.6);
            animation: toastSlide 0.4s ease;
            backdrop-filter: blur(10px);
            max-width: 380px;
            letter-spacing: 0.5px;
        }

        .toast-msg.out { animation: toastOut 0.3s ease forwards; }

        .toast-msg.ok { border-left: 3px solid var(--success); }
        .toast-msg.err { border-left: 3px solid var(--danger); }
        .toast-msg.inf { border-left: 3px solid var(--neon-blue); }

        @keyframes toastSlide {
            from { opacity: 0; transform: translateX(30px); }
            to { opacity: 1; transform: translateX(0); }
        }

        @keyframes toastOut {
            to { opacity: 0; transform: translateX(30px); }
        }

        /* ===== FOOTER ===== */
        footer {
            position: relative;
            z-index: 10;
            text-align: center;
            padding: 20px 24px;
            border-top: 1px solid var(--border);
            font-size: 10px;
            color: var(--fg-muted);
            letter-spacing: 3px;
            text-transform: uppercase;
        }

        footer a {
            color: var(--accent);
            text-decoration: none;
            border-bottom: 1px solid var(--border);
            transition: border-color 0.2s;
        }

        footer a:hover { border-color: var(--accent); }

        /* ===== RESPONSIVE ===== */
        @media (max-width: 768px) {
            .header-right { display: none; }
            .logo-text { font-size: 16px; letter-spacing: 2px; }
            .hero { padding: 36px 16px 20px; }
            .hero h1 { font-size: 24px; }
            .toolbar { gap: 8px; }
            .panel { display: none; }
            .card-grid { display: grid; }
            .cyber-btn .btn-label { display: none; }
            .hud-corner { width: 40px; height: 40px; }
        }

        @media (max-width: 480px) {
            .search-wrap { min-width: 100%; }
            main, .toolbar { padding-left: 16px; padding-right: 16px; }
        }

        @media (prefers-reduced-motion: reduce) {
            *, *::before, *::after {
                animation-duration: 0.01ms !important;
                animation-iteration-count: 1 !important;
                transition-duration: 0.01ms !important;
            }
        }
    </style>
</head>
<body>

    <!-- Background -->
    <canvas id="dataRain"></canvas>
    <div class="cyber-grid"></div>
    <div class="neon-orb o1"></div>
    <div class="neon-orb o2"></div>
    <div class="neon-orb o3"></div>

    <!-- HUD Corners -->
    <div class="hud-corner tl"></div>
    <div class="hud-corner tr"></div>
    <div class="hud-corner bl"></div>
    <div class="hud-corner br"></div>

    <!-- Header -->
    <header>
        <div class="header-line"></div>
        <div class="header-inner">
            <div class="logo">
                <div class="logo-hex">
                    <svg viewBox="0 0 50 50" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <polygon points="25,2 46,14 46,36 25,48 4,36 4,14" stroke="var(--accent)" stroke-width="1.5" fill="none"/>
                        <polygon points="25,8 40,17 40,33 25,42 10,33 10,17" stroke="var(--accent)" stroke-width="0.5" fill="none" opacity="0.4"/>
                    </svg>
                    <span>LT</span>
                </div>
                <div class="logo-text-wrap">
                    <div class="logo-text">LINETOGEL</div>
                    <div class="logo-sub">Event Nexus Interface</div>
                </div>
            </div>
            <div class="header-right">
                <div class="status-dot"></div>
                <div class="sys-clock" id="sysClock">--:--:--</div>
                <div class="hud-stat">
                    Events <span class="val" id="totalCount">--</span>
                </div>
                <div class="hud-stat">
                    Active <span class="val" id="activeCount">--</span>
                </div>
            </div>
        </div>
        <div class="header-line"></div>
    </header>

    <!-- Hero -->
    <section class="hero">
        <div class="hero-tag">
            <span class="dot-blink"></span>
            System Online — Real-time Data Feed
        </div>
        <h1>
            <span class="glitch" data-text="EVENT">EVENT</span>
            <br>
            <span class="glitch" data-text="LINETOGEL">LINETOGEL</span>
        </h1>
        <p class="hero-sub">
            Stream data event langsung dari sumber. Ketik <span class="cmd">Ctrl+K</span> untuk pencarian cepat, atau tekan <span class="cmd">Refresh</span> untuk sinkronisasi ulang.
        </p>
    </section>

    <!-- Toolbar -->
    <div class="toolbar">
        <div class="search-wrap">
            <span class="prefix">&gt;_</span>
            <input type="text" id="searchInput" placeholder="query_search..." aria-label="Cari event">
        </div>
        <div class="view-group" role="group" aria-label="Mode tampilan">
            <button id="viewTable" class="active" title="Tabel" aria-label="Tabel"><i class="fas fa-table-list"></i></button>
            <button id="viewCard" title="Kartu" aria-label="Kartu"><i class="fas fa-grip"></i></button>
        </div>
        <button class="cyber-btn primary" id="refreshBtn" aria-label="Refresh data">
            <i class="fas fa-arrows-rotate"></i>
            <span class="btn-label">Sync</span>
        </button>
    </div>

    <!-- Main -->
    <main id="mainContent">
        <div class="loading-box" id="loadingState">
            <div class="hex-loader">
                <svg viewBox="0 0 50 50" fill="none">
                    <polygon points="25,2 46,14 46,36 25,48 4,36 4,14" stroke="var(--accent)" stroke-width="1.5" fill="none"/>
                    <polygon points="25,10 38,18 38,32 25,40 12,32 12,18" stroke="var(--accent)" stroke-width="0.8" fill="none" opacity="0.5"/>
                </svg>
            </div>
            <div class="loading-label">Fetching Data Stream...</div>
            <div class="loading-bar"><div class="loading-bar-inner"></div></div>
        </div>
    </main>

    <!-- Toast -->
    <div class="toast-stack" id="toastStack"></div>

    <!-- Footer -->
    <footer>
        Data source: <a href="https://docs.google.com/spreadsheets/d/1uymGF_AHUstAJ9je9kw9ZAldKMs45OYFGbNz7Dr1L2Y/edit?gid=1502421415#gid=1502421415" target="_blank" rel="noopener">Google Sheets</a> &mdash; Linetogel Event Nexus v2.0
    </footer>

    <script>
        // ============================================
        // DATA RAIN CANVAS (efek matrix ringan)
        // ============================================
        const rainCanvas = document.getElementById('dataRain');
        const rCtx = rainCanvas.getContext('2d');
        let rainCols = [];

        function initRain() {
            rainCanvas.width = window.innerWidth;
            rainCanvas.height = window.innerHeight;
            const colW = 18;
            const numCols = Math.floor(rainCanvas.width / colW);
            rainCols = Array.from({ length: numCols }, () => ({
                x: Math.random() * rainCanvas.width,
                y: Math.random() * rainCanvas.height,
                speed: 0.3 + Math.random() * 1.2,
                chars: '0123456789ABCDEF'.split(''),
                char: '',
                timer: 0
            }));
        }

        function drawRain() {
            rCtx.fillStyle = 'rgba(2, 4, 8, 0.12)';
            rCtx.fillRect(0, 0, rainCanvas.width, rainCanvas.height);

            rCtx.font = '11px "Share Tech Mono", monospace';

            rainCols.forEach(col => {
                col.timer++;
                if (col.timer % 4 === 0) {
                    col.char = col.chars[Math.floor(Math.random() * col.chars.length)];
                }

                // Tail
                rCtx.fillStyle = 'rgba(0, 255, 200, 0.06)';
                rCtx.fillText(col.char, col.x, col.y);

                // Head
                rCtx.fillStyle = 'rgba(0, 255, 200, 0.15)';
                rCtx.fillText(col.char, col.x, col.y);

                col.y += col.speed;
                if (col.y > rainCanvas.height) {
                    col.y = -20;
                    col.x = Math.random() * rainCanvas.width;
                }
            });

            requestAnimationFrame(drawRain);
        }

        initRain();
        drawRain();
        window.addEventListener('resize', initRain);

        // ============================================
        // SYSTEM CLOCK
        // ============================================
        function updateClock() {
            const now = new Date();
            document.getElementById('sysClock').textContent =
                now.toLocaleTimeString('en-GB', { hour12: false });
        }
        updateClock();
        setInterval(updateClock, 1000);

        // ============================================
        // KONFIGURASI
        // ============================================
        const SPREADSHEET_ID = '1uymGF_AHUstAJ9je9kw9ZAldKMs45OYFGbNz7Dr1L2Y';
        const GID = '1502421415';
        const CSV_URL = `https://docs.google.com/spreadsheets/d/${SPREADSHEET_ID}/export?format=csv&gid=${GID}`;

        // ============================================
        // STATE
        // ============================================
        let headers = [];
        let rows = [];
        let filteredRows = [];
        let sortCol = -1;
        let sortDir = 'asc';
        let currentView = 'table';

        const mainEl = document.getElementById('mainContent');
        const loadingEl = document.getElementById('loadingState');
        const searchInput = document.getElementById('searchInput');
        const refreshBtn = document.getElementById('refreshBtn');
        const viewTableBtn = document.getElementById('viewTable');
        const viewCardBtn = document.getElementById('viewCard');

        // ============================================
        // TOAST
        // ============================================
        function toast(msg, type = 'inf') {
            const stack = document.getElementById('toastStack');
            const el = document.createElement('div');
            el.className = `toast-msg ${type}`;
            const ic = { ok: 'fa-circle-check', err: 'fa-circle-xmark', inf: 'fa-terminal' };
            el.innerHTML = `<i class="fas ${ic[type] || ic.inf}" style="opacity:0.7"></i><span>${msg}</span>`;
            stack.appendChild(el);
            setTimeout(() => {
                el.classList.add('out');
                setTimeout(() => el.remove(), 300);
            }, 3800);
        }

        // ============================================
        // CSV PARSER
        // ============================================
        function parseCSV(text) {
            const result = [];
            let cur = '', inQ = false, row = [];
            for (let i = 0; i < text.length; i++) {
                const ch = text[i], nx = text[i + 1];
                if (inQ) {
                    if (ch === '"' && nx === '"') { cur += '"'; i++; }
                    else if (ch === '"') inQ = false;
                    else cur += ch;
                } else {
                    if (ch === '"') inQ = true;
                    else if (ch === ',') { row.push(cur.trim()); cur = ''; }
                    else if (ch === '\n' || (ch === '\r' && nx === '\n')) {
                        row.push(cur.trim()); cur = '';
                        if (row.some(c => c !== '')) result.push(row);
                        row = [];
                        if (ch === '\r') i++;
                    } else if (ch === '\r') {
                        row.push(cur.trim()); cur = '';
                        if (row.some(c => c !== '')) result.push(row);
                        row = [];
                    } else cur += ch;
                }
            }
            row.push(cur.trim());
            if (row.some(c => c !== '')) result.push(row);
            return result;
        }

        // ============================================
        // STATUS DETECTION
        // ============================================
        function statusTag(v) {
            if (!v) return '';
            const l = v.toLowerCase();
            if ((l.includes('aktif') || l.includes('active') || l.includes('live') || l.includes('running')) && !l.includes('non') && !l.includes('tidak')) {
                return `<span class="tag tag-aktif">${esc(v)}</span>`;
            }
            if (l.includes('nonaktif') || l.includes('tidak aktif') || l.includes('selesai') || l.includes('expired') || l.includes('ditutup') || l.includes('berakhir') || l.includes('ended') || l.includes('closed')) {
                return `<span class="tag tag-off">${esc(v)}</span>`;
            }
            if (l.includes('menunggu') || l.includes('pending') || l.includes('proses') || l.includes('review') || l.includes('waiting')) {
                return `<span class="tag tag-wait">${esc(v)}</span>`;
            }
            if (l.includes('segera') || l.includes('upcoming') || l.includes('soon') || l.includes('mendatang')) {
                return `<span class="tag tag-warn">${esc(v)}</span>`;
            }
            return esc(v);
        }

        function isStatusCol(h) {
            const l = h.toLowerCase();
            return l.includes('status') || l.includes('state') || l.includes('ket') || l.includes('kondisi') || l === 'kategori' || l === 'type';
        }

        function countActive() {
            let c = 0;
            rows.forEach(r => {
                const any = Object.values(r).some(v => {
                    const l = v.toLowerCase();
                    return (l.includes('aktif') || l.includes('active') || l.includes('live')) && !l.includes('non') && !l.includes('tidak');
                });
                if (any) c++;
            });
            return c;
        }

        function esc(s) {
            const d = document.createElement('div');
            d.textContent = s;
            return d.innerHTML;
        }

        // ============================================
        // RENDER TABLE
        // ============================================
        function renderTable() {
            const d = filteredRows;
            let h = `<div class="panel"><div class="panel-header">
                <span>Displaying <span class="cnt">${d.length}</span> records of ${rows.length}</span>
                <span style="opacity:0.5;font-size:10px;">CLICK_HEADER_TO_SORT</span>
            </div><div class="table-scroll"><table class="dtable"><thead><tr><th style="width:48px;cursor:default">#</th>`;

            headers.forEach((hd, i) => {
                const sorted = sortCol === i;
                const arrow = sorted ? (sortDir === 'asc' ? 'fa-caret-up' : 'fa-caret-down') : 'fa-sort';
                h += `<th class="${sorted ? 'sorted' : ''}" data-c="${i}">${esc(hd)} <i class="fas ${arrow} srt"></i></th>`;
            });

            h += `</tr></thead><tbody>`;

            if (!d.length) {
                h += `<tr><td colspan="${headers.length + 1}"><div class="no-data"><i class="fas fa-database"></i><p>NO_MATCHING_RECORDS_FOUND</p></div></td></tr>`;
            } else {
                d.forEach((row, idx) => {
                    h += `<tr><td><span class="row-idx">${String(idx + 1).padStart(2, '0')}</span></td>`;
                    headers.forEach(hd => {
                        const val = row[hd] || '';
                        const display = isStatusCol(hd) ? statusTag(val) : esc(val);
                        h += `<td>${display}</td>`;
                    });
                    h += `</tr>`;
                });
            }

            h += `</tbody></table></div></div>`;
            return h;
        }

        // ============================================
        // RENDER CARDS
        // ============================================
        function renderCards() {
            const d = filteredRows;
            if (!d.length) return `<div class="no-data"><i class="fas fa-database"></i><p>NO_MATCHING_RECORDS_FOUND</p></div>`;

            let h = '<div class="card-grid">';
            d.forEach((row, idx) => {
                h += `<div class="ev-card" style="animation-delay:${idx * 0.04}s">`;
                headers.forEach(hd => {
                    const val = row[hd] || '';
                    const display = isStatusCol(hd) ? statusTag(val) : esc(val);
                    h += `<div class="c-row"><span class="c-label">${esc(hd)}</span><span class="c-val">${display}</span></div>`;
                });
                h += `</div>`;
            });
            h += '</div>';
            return h;
        }

        // ============================================
        // RENDER
        // ============================================
        function render() {
            if (!rows.length) return;
            mainEl.innerHTML = currentView === 'table' ? renderTable() : renderCards();
            bindSort();
        }

        function bindSort() {
            document.querySelectorAll('.dtable th[data-c]').forEach(th => {
                th.addEventListener('click', () => {
                    const c = parseInt(th.dataset.c);
                    if (sortCol === c) sortDir = sortDir === 'asc' ? 'desc' : 'asc';
                    else { sortCol = c; sortDir = 'asc'; }
                    doSort();
                    render();
                });
            });
        }

        function doSort() {
            if (sortCol < 0) return;
            const key = headers[sortCol];
            filteredRows.sort((a, b) => {
                let va = (a[key] || '').toLowerCase();
                let vb = (b[key] || '').toLowerCase();
                const na = parseFloat(va), nb = parseFloat(vb);
                if (!isNaN(na) && !isNaN(nb)) return sortDir === 'asc' ? na - nb : nb - na;
                return sortDir === 'asc' ? va.localeCompare(vb) : vb.localeCompare(va);
            });
        }

        function applySearch() {
            const q = searchInput.value.toLowerCase().trim();
            filteredRows = q ? rows.filter(r => Object.values(r).some(v => v.toLowerCase().includes(q))) : [...rows];
            doSort();
            render();
        }

        // ============================================
        // FETCH
        // ============================================
        async function fetchData() {
            mainEl.innerHTML = '';
            mainEl.appendChild(loadingEl);
            loadingEl.style.display = '';
            refreshBtn.classList.add('spinning');

            try {
                const res = await fetch(CSV_URL);
                if (!res.ok) throw new Error(`HTTP_ERR_${res.status}`);

                const txt = await res.text();
                const parsed = parseCSV(txt);

                if (parsed.length < 2) throw new Error('DATA_SET_EMPTY');

                headers = parsed[0].filter(h => h !== '');
                const rawData = parsed.slice(1);
                rows = rawData.map(row => {
                    const obj = {};
                    headers.forEach((h, i) => { obj[h] = row[i] !== undefined ? row[i] : ''; });
                    return obj;
                });

                filteredRows = [...rows];
                sortCol = -1;
                sortDir = 'asc';
                searchInput.value = '';

                document.getElementById('totalCount').textContent = rows.length;
                document.getElementById('activeCount').textContent = countActive();

                render();
                toast(`LOADED ${rows.length} RECORDS SUCCESSFULLY`, 'ok');

            } catch (err) {
                console.error(err);
                mainEl.innerHTML = `
                    <div class="error-box">
                        <div class="err-icon"><i class="fas fa-triangle-exclamation"></i></div>
                        <div class="err-code">ERR::${err.message}</div>
                        <h3>CONNECTION FAILED</h3>
                        <p>Pastikan spreadsheet diatur ke publik (Anyone with the link &rarr; Viewer) lalu coba lagi.</p>
                        <button class="cyber-btn" onclick="fetchData()">
                            <i class="fas fa-arrows-rotate"></i> Retry Connection
                        </button>
                    </div>`;
                toast(`FETCH_FAILED: ${err.message}`, 'err');
            } finally {
                refreshBtn.classList.remove('spinning');
            }
        }

        // ============================================
        // EVENTS
        // ============================================
        refreshBtn.addEventListener('click', fetchData);
        searchInput.addEventListener('input', applySearch);

        viewTableBtn.addEventListener('click', () => {
            if (currentView === 'table') return;
            currentView = 'table';
            viewTableBtn.classList.add('active');
            viewCardBtn.classList.remove('active');
            render();
        });

        viewCardBtn.addEventListener('click', () => {
            if (currentView === 'card') return;
            currentView = 'card';
            viewCardBtn.classList.add('active');
            viewTableBtn.classList.remove('active');
            render();
        });

        document.addEventListener('keydown', e => {
            if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
                e.preventDefault();
                searchInput.focus();
            }
        });

        // ============================================
        // INIT
        // ============================================
        fetchData();
    </script>
</body>
</html>
